# 2026 World Cup Predictor - API Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# football-data.org (免费计划：12个联赛/杯赛，10请求/分钟)
# 注册获取API Key：https://www.football-data.org/register
# 世界杯代码：WC (FIFA World Cup)
# ============================================================================
VITE_FOOTBALL_DATA_API_KEY=

# ============================================================================
# The Odds API (免费计划：25请求/天，NBA/MLB h2h)
# Business计划：$99/月，200k请求，所有体育包括世界杯，50+博彩公司
# 注册获取API Key：https://theoddsapi.com/
# ============================================================================
VITE_ODDS_API_KEY=

# ============================================================================
# API-Football (免费计划：100请求/天，赛程/结果)
# 赔率 Addon：$15/月
# 注册获取API Key：https://dashboard.api-football.com/register
# ============================================================================
VITE_API_FOOTBALL_KEY=

# ============================================================================
# 轮询配置
# ============================================================================
# 是否启用自动轮询（每5分钟刷新数据）
VITE_ENABLE_POLLING=true

# 轮询间隔（毫秒，默认5分钟 = 300000）
VITE_POLLING_INTERVAL=300000

# 缓存过期时间（毫秒，默认10分钟 = 600000）
VITE_CACHE_TTL=600000
